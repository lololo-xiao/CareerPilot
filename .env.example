GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=project-75f75b99-d907-4aa0-abd
GOOGLE_CLOUD_LOCATION=global
GEMINI_MODEL=gemini-2.5-flash

# Optional web search backend for the Job Pool "Search with AI" tab.
# Configure one provider. Serper is the default when SERPER_API_KEY is set.
# JOB_SEARCH_PROVIDER=serper
# SERPER_API_KEY=your-serper-key
# JOB_SEARCH_PROVIDER=tavily
# TAVILY_API_KEY=your-tavily-key
# JOB_SEARCH_PROVIDER=brave
# BRAVE_SEARCH_API_KEY=your-brave-search-key
# JOB_SEARCH_PROVIDER=google_cse
# GOOGLE_CSE_API_KEY=your-google-cse-key
# GOOGLE_CSE_ID=your-google-custom-search-engine-id

# Phoenix / Arize for the hackathon track. Used for BOTH OpenTelemetry tracing
# AND the runtime Phoenix MCP server (agent memory + self-improvement).
# Create a Phoenix API key at https://app.phoenix.arize.com.
PHOENIX_API_KEY=
# Phoenix Cloud: copy the Hostname from Phoenix Settings. It usually includes /s/<space>.
# Example: https://app.phoenix.arize.com/s/your-space
PHOENIX_COLLECTOR_ENDPOINT=
PHOENIX_PROJECT_NAME=careerpilot
# Phoenix prompt that stores the agent's learned ranking rubric (cross-run memory).
# Phoenix strips hyphens from prompt names, so use underscores.
PHOENIX_RUBRIC_PROMPT=careerpilot_rubric

# Agentic loop controls.
# Min evaluator score (1-5) the ranking must reach before the agent stops.
EVAL_THRESHOLD=4
# Max self-improvement (rubric upgrade + re-rank) passes before forced stop.
MAX_IMPROVE_ITERS=2

# Phoenix MCP server invocation. In a container with the server pre-installed
# globally, set PHOENIX_MCP_PACKAGE=@arizeai/phoenix-mcp (no @latest) to skip the
# per-call npm registry check.
# PHOENIX_MCP_PACKAGE=@arizeai/phoenix-mcp@latest
# PHOENIX_MCP_COMMAND=npx
# PHOENIX_MCP_TIMEOUT=90

# Alternative Gemini API key mode:
# GOOGLE_GENAI_USE_VERTEXAI=false
# GEMINI_API_KEY=your-api-key

# Optional service account file for Vertex AI:
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
