GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=project-75f75b99-d907-4aa0-abd
GOOGLE_CLOUD_LOCATION=global
GEMINI_MODEL=gemini-2.5-flash

# Phoenix / Arize tracing for the hackathon track.
# Create a Phoenix API key at https://app.phoenix.arize.com.
PHOENIX_API_KEY=
# Phoenix Cloud: copy the Hostname from Phoenix Settings. It usually includes /s/<space>.
# Example: https://app.phoenix.arize.com/s/your-space
PHOENIX_COLLECTOR_ENDPOINT=
PHOENIX_PROJECT_NAME=careerpilot

# Alternative Gemini API key mode:
# GOOGLE_GENAI_USE_VERTEXAI=false
# GEMINI_API_KEY=your-api-key

# Optional service account file for Vertex AI:
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
